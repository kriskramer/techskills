# Firebase web app config (Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Cloud Functions region (defaults to us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Set to "true" to skip Google sign-in on recruiter routes during local dev.
# Only honored when running `npm run dev` (import.meta.env.DEV). Ignored in production builds.
VITE_DISABLE_RECRUITER_AUTH=

# Set to "true" to show the recruiter "View Test" button (test preview with answer key).
# Off by default; intended for local/testing use until ready for production.
# VITE_ENABLE_TEST_PREVIEW=true
