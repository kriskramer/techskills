rules_version = '2';

// MVP/SCAFFOLD ONLY — no auth on candidates or tests. Revisit before production.
// The private subcollection (tests/{token}/private/*) is locked to server-side
// only (Cloud Functions use the Admin SDK which bypasses these rules).
service cloud.firestore {
  match /databases/{database}/documents {
    match /candidates/{candidateId} {
      allow read, write: if true;
    }

    match /tests/{token} {
      allow read, write: if true;

      // Answer keys are stored here and must never be readable by clients.
      match /private/{doc} {
        allow read, write: if false;
      }
    }
  }
}
