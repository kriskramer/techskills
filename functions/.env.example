# Local emulator only. For deployed environments, set these as Functions
# secrets instead:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#   firebase functions:secrets:set RESEND_API_KEY

ANTHROPIC_API_KEY=

# Resend (resend.com) — used by the sendInvitation Cloud Function.
# Sign up at resend.com, verify a sending domain, and paste your API key here.
RESEND_API_KEY=

# The "from" address for invitation emails. Must be from a verified Resend domain.
# Defaults to onboarding@resend.dev (free tier only — sends to your own email only).
RESEND_FROM_EMAIL=

# The recruiter email address that receives a notification when a test is completed.
RECRUITER_EMAIL=
